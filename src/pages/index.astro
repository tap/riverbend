---
// Homepage. For now it's the hero; the remaining sections (trust strip, services,
// gallery, testimonials, service area, how-it-works, final CTA) come next and will
// slot in below the hero as their own components. See PROJECT_BRIEF.md §6.

import BaseLayout from "../layouts/BaseLayout.astro";
import TrustStrip from "../components/TrustStrip.astro";
import Services from "../components/Services.astro";
import Contact from "../components/Contact.astro";
import { business } from "../data/business.ts";
---

<BaseLayout
  title="Handyman Services"
  description="Honest, on-time handyman work across the Kansas City metro — repairs, carpentry, painting, mounting, and more. Call for a free quote."
>
  <section class="hero">
    <div class="container hero__inner">
      <p class="hero__eyebrow">Serving the {business.serviceArea}</p>
      <h1 class="hero__title">Honest, on-time handyman for your home.</h1>
      <p class="hero__lead">
        From nagging repairs to the projects on your list — {business.shortName} gets
        it done right, shows up when we say we will, and cleans up after.
      </p>

      <div class="hero__cta">
        <a href={business.phone.href} class="hero__phone">
          📞 {business.phone.display}
        </a>
        <a href="#contact" class="btn btn--primary">Get a Free Quote</a>
      </div>

      <p class="hero__hours">{business.hours}</p>
    </div>
  </section>

  <TrustStrip />

  <Services />

  <Contact />
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(
      180deg,
      var(--cream) 0%,
      var(--cream-panel) 100%
    );
    padding-block: clamp(3rem, 9vw, 6rem);
  }

  .hero__inner {
    max-width: 46rem;
  }

  .hero__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--rust-dark);
    margin: 0 0 0.75rem;
  }

  .hero__title {
    font-size: clamp(2rem, 6vw, 3.25rem);
    margin: 0 0 1rem;
  }

  .hero__lead {
    font-size: clamp(1.05rem, 2.5vw, 1.25rem);
    color: var(--ink-soft);
    margin: 0 0 2rem;
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.5rem;
  }

  .hero__phone {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 800;
    color: var(--brown);
    text-decoration: none;
    white-space: nowrap;
  }
  .hero__phone:hover {
    color: var(--rust-dark);
  }

  .hero__hours {
    margin-top: 1.25rem;
    color: var(--ink-soft);
    font-size: 0.95rem;
  }
</style>
