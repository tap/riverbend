---
// Recent-work gallery (PROJECT_BRIEF.md §6 #4). Homepage shows a handful of
// projects; a full before/after gallery page can come later.
//
// Images live in src/assets/gallery/ so Astro's <Image> optimizes them at BUILD
// time — the 5–6 MB phone photos get downscaled + re-encoded to small modern
// formats automatically. Visitors never download the originals.
//
// import.meta.glob loads every file in the folder so Astro knows to process them.
// `eager: true` imports them up front (vs. returning lazy import functions).

import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { business } from "../data/business.ts";

const files = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/gallery/*.{jpg,jpeg,png,avif}",
  { eager: true },
);

// PLACEHOLDER captions/categories — these photos are stand-ins. Replace with real
// project descriptions (and ideally before/after pairs) once the owner supplies them.
const featured = [
  { file: "PXL_20240413_161630153.PORTRAIT.jpg", caption: "Deck board repair", category: "Outdoor & Decks" },
  { file: "PXL_20230904_173224983.jpg", caption: "Fence repair", category: "Outdoor & Decks" },
  { file: "PXL_20220313_184239306.jpg", caption: "Interior trim & paint", category: "Carpentry & Repair" },
  { file: "IMG_7699.jpg", caption: "Fixture replacement", category: "Minor Plumbing" },
  { file: "fa0ee32c-19e9-4a71-bbcd-1a5b6e4f8fb9.avif", caption: "Drywall patch & finish", category: "Carpentry & Repair" },
  { file: "1a3c2452-002d-4b93-93ce-2e7e4970dba7.avif", caption: "TV & shelf mounting", category: "Mounting & Assembly" },
];

const items = featured
  .map((f) => {
    const mod = files[`../assets/gallery/${f.file}`];
    return mod ? { ...f, img: mod.default } : null;
  })
  .filter(Boolean) as {
  file: string;
  caption: string;
  category: string;
  img: ImageMetadata;
}[];
---

<section id="gallery" class="gallery">
  <div class="container">
    <header class="gallery__head">
      <p class="eyebrow">Recent work</p>
      <h2>See the work for yourself</h2>
      <p class="gallery__intro">
        A few recent projects around the {business.serviceArea}. Honest work, done right.
      </p>
    </header>

    <ul class="gallery__grid" role="list">
      {
        items.map((item) => (
          <li class="shot">
            <Image src={item.img} alt={item.caption} width={800} loading="lazy" class="shot__img" />
            <div class="shot__meta">
              <span class="shot__cat">{item.category}</span>
              <span class="shot__caption">{item.caption}</span>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .gallery {
    padding-block: clamp(3rem, 8vw, 5rem);
  }

  .gallery__head {
    max-width: 42rem;
    margin-bottom: 2.5rem;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--rust-dark);
    margin: 0 0 0.5rem;
  }
  .gallery__head h2 {
    font-size: clamp(1.7rem, 4vw, 2.4rem);
    margin: 0 0 0.75rem;
  }
  .gallery__intro {
    color: var(--ink-soft);
    font-size: 1.1rem;
    margin: 0;
  }

  .gallery__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: 1rem;
  }

  .shot {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--cream-panel);
  }
  .shot__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .shot:hover .shot__img {
    transform: scale(1.04);
  }

  /* Caption sits over a gradient scrim at the bottom of the photo. */
  .shot__meta {
    position: absolute;
    inset: auto 0 0 0;
    padding: 1.5rem 1rem 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    color: #fff;
    background: linear-gradient(to top, rgba(40, 27, 17, 0.85), transparent);
    pointer-events: none;
  }
  .shot__cat {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.85;
  }
  .shot__caption {
    font-weight: 700;
  }
</style>
